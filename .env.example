# Frontend environment - BROWSER-SAFE VALUES ONLY.
# Copy this file to .env.local and fill in real values for local development.
# Never put Supabase secret keys, Google secrets, refresh tokens, or the Bing
# API key in this file - those belong only in Supabase Edge Function secrets.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
VITE_APP_URL=http://localhost:5173

# Optional. Your Supabase plan's database-size limit in MB, for the usage gauge
# on the System page. Free = 500, Pro = 8192. Defaults to 500 if unset.
VITE_DB_SIZE_LIMIT_MB=500
